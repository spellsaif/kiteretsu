{
  "name": "kiteretsu-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "Agent memory, codebase intelligence, and context compiler for AI coding agents",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "cli": "pnpm --filter kiteretsu start",
    "mcp": "pnpm --filter @kiteretsu/mcp-server start",
    "server": "pnpm --filter @kiteretsu/server dev",
    "dashboard": "pnpm --filter dashboard dev"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "context",
    "mcp",
    "coding-agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "rimraf": "^5.0.0",
    "turbo": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "tree-sitter",
      "tree-sitter-bash",
      "tree-sitter-c",
      "tree-sitter-c-sharp",
      "tree-sitter-cpp",
      "tree-sitter-dart",
      "tree-sitter-elixir",
      "tree-sitter-go",
      "tree-sitter-html",
      "tree-sitter-java",
      "tree-sitter-javascript",
      "tree-sitter-julia",
      "tree-sitter-kotlin",
      "tree-sitter-lua",
      "tree-sitter-objc",
      "tree-sitter-php",
      "tree-sitter-python",
      "tree-sitter-ruby",
      "tree-sitter-rust",
      "tree-sitter-scala",
      "tree-sitter-svelte",
      "tree-sitter-swift",
      "tree-sitter-typescript",
      "tree-sitter-verilog",
      "tree-sitter-vue",
      "tree-sitter-zig"
    ]
  }
}