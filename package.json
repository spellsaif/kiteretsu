{
  "name": "kiteretsu-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "Agent memory, codebase intelligence, and context compiler for AI coding agents",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "cli": "pnpm --filter kiteretsu start",
    "mcp": "pnpm --filter @kiteretsu/mcp-server start",
    "server": "pnpm --filter @kiteretsu/server dev",
    "dashboard": "pnpm --filter dashboard dev"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "context",
    "mcp",
    "coding-agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "rimraf": "^5.0.0",
    "tsx": "^4.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "protobufjs",
      "sharp"
    ]
  }
}